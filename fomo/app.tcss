/* fomo global styles */

Screen {
    background: $surface;
}

Header {
    background: $primary;
    color: $foreground;
}

/* Shared layout */
#main {
    padding: 1 2;
    height: 1fr;
}

/* Loading / status labels */
#loading-label {
    margin: 1 0;
    color: $text-muted;
    text-style: italic;
}

#status {
    height: 1;
    color: $text-muted;
    margin-top: 1;
}

/* Scope screen */
SelectionList {
    height: 1fr;
    border: round $panel;
}

/* SelectionList checkbox contrast fix (dark + light mode) */
SelectionList > .selection-list--button {
    color: $text-muted;
}

SelectionList > .selection-list--button-highlighted {
    color: $text-muted;
}

SelectionList > .selection-list--button-selected {
    color: $success;
}

SelectionList > .selection-list--button-selected-highlighted {
    color: $success;
}

/* Roles screen */
#filter {
    margin: 1 0;
}

/* Split-view selection screens (roles + entra) */
#loading-area {
    padding: 1 2;
    height: 1fr;
}

#split {
    height: 1fr;
}

#left-pane {
    width: 2fr;
    padding: 0 1;
}

#detail-pane {
    width: 1fr;
    border-left: solid $panel;
    padding: 1 2;
    overflow-y: auto;
    background: $boost;
}

#detail {
    width: 1fr;
    height: auto;
}

/* Activation screen */
DataTable {
    height: auto;
    max-height: 14;
    border: round $panel;
    margin-bottom: 1;
}

#form Label {
    margin-top: 1;
    color: $text-muted;
}

#buttons {
    height: 3;
    margin-top: 1;
    align: left middle;
}

#btn-activate {
    margin-right: 2;
}

/* Global assignments warning box */
#global-roles-box {
    border: round $warning;
    padding: 0 1;
    margin-bottom: 1;
}

#global-roles-box Label {
    margin: 1 0;
    color: $text;
}

#global-roles-box DataTable {
    margin-bottom: 0;
}

/* Error log panel (shown only on activation errors) */
#error-log {
    height: 10;
    border: round $error;
    margin-top: 1;
    background: $surface-darken-1;
}

/* Scope screen tabs */
#scope-tabs {
    height: 1fr;
}

/* Entra tab pane within ScopeScreen */
#entra-loading-area {
    padding: 1 2;
    height: 1fr;
}

#entra-split {
    height: 1fr;
}

#entra-left-pane {
    width: 2fr;
    padding: 0 1;
}

#entra-detail-pane {
    width: 1fr;
    border-left: solid $panel;
    padding: 1 2;
    overflow-y: auto;
    background: $boost;
}

#entra-detail {
    width: 1fr;
    height: auto;
}

#entra-filter {
    margin: 1 0;
}

#entra-status {
    height: 1;
    color: $text-muted;
    margin-top: 1;
}

/* Assignments screen */
#assignment-tabs {
    height: 1fr;
}

#azure-table, #entra-table {
    height: 1fr;
    max-height: 100;
    margin-top: 1;
}

.hidden {
    display: none;
}
